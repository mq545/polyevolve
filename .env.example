# =============================================================================
# Model selection: every model goes through LiteLLM. The model id carries the
# provider, and LiteLLM reads that provider's config from the env itself.
# =============================================================================
#   DEFAULT_MODEL=ollama/qwen3:30b-a3b-instruct-2507-q4_K_M  (default; local Ollama)
#   DEFAULT_MODEL=ollama/qwen2.5:14b                         (lighter local model)
#   DEFAULT_MODEL=hosted_vllm/qwen3-30b                      (vLLM server; set VLLM_API_BASE)
#   DEFAULT_MODEL=anthropic/claude-sonnet-4-6               (needs ANTHROPIC_API_KEY)
#   DEFAULT_MODEL=openai/gpt-4o                              (needs OPENAI_API_KEY)
#
# Local dev path: install Ollama (https://ollama.com/download), then:
#   ollama pull qwen3:30b-a3b-instruct-2507-q4_K_M
# Ollama listens on localhost:11434 by default; override with OLLAMA_API_BASE.

DEFAULT_MODEL=ollama/qwen3:30b-a3b-instruct-2507-q4_K_M

# =============================================================================
# Anthropic (only needed if DEFAULT_MODEL starts with "anthropic/")
# =============================================================================
# ANTHROPIC_API_KEY=

# =============================================================================
# Ollama (only needed if DEFAULT_MODEL starts with "ollama/")
# =============================================================================
# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# OpenAI (only needed if DEFAULT_MODEL starts with "openai/")
# =============================================================================
# OPENAI_API_KEY=

# =============================================================================
# Kalshi (deferred to v0.1; placeholder)
# =============================================================================
# KALSHI_API_KEY=
# KALSHI_PRIVATE_KEY_PATH=

# =============================================================================
# Polymarket Gamma API is public; no key required for read access.
# =============================================================================

# =============================================================================
# API etiquette: Wikipedia / Wikimedia pageviews ask for a contact in the
# User-Agent (they may throttle a generic UA). Set to your email or project URL.
# =============================================================================
# POLYEVOLVE_CONTACT=you@example.com

# =============================================================================
# Postgres (matches docker-compose.yml defaults)
# =============================================================================
DB_URL=postgresql://superpod:superpod@localhost:5432/superpod

# =============================================================================
# Optional: news APIs (multilingual coverage - v1)
# =============================================================================
# NEWSAPI_KEY=

# =============================================================================
# Optional: Langfuse LLM observability
# =============================================================================
# Off unless both keys are set AND `uv add langfuse` has been run.
# Fastest path: create a free project at https://cloud.langfuse.com
#   LANGFUSE_PUBLIC_KEY=pk-lf-...
#   LANGFUSE_SECRET_KEY=sk-lf-...
#   LANGFUSE_HOST=https://cloud.langfuse.com
# Self-hosted: point LANGFUSE_HOST at your own Langfuse stack instead.
# When unset, every LLM call is still fully traced to the Postgres llm_calls
# table (inspect via `uv run python -m polyevolve.cli traces`).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
